# Liara Engine - EditorConfig file
# For more information, see https://editorconfig.org

root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{cpp,h}]
indent_style = space
indent_size = 4
max_line_length = 120

[{CMakeLists.txt,*.cmake,*.cmake.in}]
indent_style = space
indent_size = 4

[*.{yml,yaml,json}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false
indent_style = space
indent_size = 4

[*.{toml,ini,cfg}]
indent_style = space
indent_size = 2

[*.{sh,ps1}]
indent_style = space
indent_size = 2

[{Makefile,*.mk}]
indent_style = tab